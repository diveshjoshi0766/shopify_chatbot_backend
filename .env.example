# Copy this file to backend/.env and fill in values (never commit .env)
#
# The app always loads: backend/.env (see app/settings.py), regardless of cwd.
# Optional: from repo root, `ln -s backend/.env .env` so `.env` appears at project root.

# MongoDB Atlas (database name in URI path) — all app data uses one collection (see MONGODB_COLLECTION).
# URL-encode special characters in the password.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/YourDatabase?retryWrites=true&w=majority
MONGODB_COLLECTION=dyspensr_ai_bot
# If the URI has no database path, set explicitly:
# MONGODB_DATABASE=YourDatabase

OPENAI_API_KEY=

# CORS — comma-separated allowed origins. Set to * for wildcard (credentials disabled).
# CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080,http://127.0.0.1:3000

# Shopify Dev MCP (https://shopify.dev/docs/apps/build/devmcp) — singleton session started
# at server boot for learn/introspect/docs/validate tools. Requires Node 18+ and `pip install mcp`.
# SHOPIFY_DEV_MCP_ENABLED=true
# SHOPIFY_DEV_MCP_COMMAND=npx
# SHOPIFY_DEV_MCP_ARGS=-y @shopify/dev-mcp@latest
# SHOPIFY_DEV_MCP_OPT_OUT_INSTRUMENTATION=false
# SHOPIFY_DEV_MCP_LIQUID_VALIDATION_MODE=

SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
SHOPIFY_APP_REDIRECT_URI=http://127.0.0.1:8004/shopify/callback

# Optional: legacy encrypted DB tokens
# ENCRYPTION_KEY_BASE64=

# --- User registration ---
# When BOTH are set: (1) POST /auth/register requires admin_email + admin_password (UI: #/admin/register).
# (2) On API startup, that admin user is created (or gets a password if missing) so POST /auth/login works.
# AUTH_ADMIN_REGISTER_EMAIL=admin@dyspensr.com
# AUTH_ADMIN_REGISTER_PASSWORD=
# AUTH_REGISTRATION_PASSWORD=
# New users must set a password (min 8 chars) at registration; login uses email + password.
# AUTH_ADMIN_EMAIL=
# DEFAULT_TENANT_ID=t1
